# Default: treat all text files as LF on checkout/checkin
* text=auto eol=lf

*.php        text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.cff        text eol=lf
*.bib        text eol=lf
*.xml        text eol=lf

# ────────────────────────────────────────────────────────────────────
# Exclude development-only files from the Packagist distribution.
# Reduces package size for downstream users.
# ────────────────────────────────────────────────────────────────────
/.editorconfig       export-ignore
/.gitattributes      export-ignore
/.gitignore          export-ignore
/.github             export-ignore
/tests               export-ignore
/examples            export-ignore
/docs                export-ignore
/paper.md            export-ignore
/paper.bib           export-ignore
/phpunit.xml         export-ignore
/autoload.php        export-ignore
/CONTRIBUTING.md     export-ignore
/CODE_OF_CONDUCT.md  export-ignore
/SECURITY.md         export-ignore

# ────────────────────────────────────────────────────────────────────
# GitHub language statistics
# ────────────────────────────────────────────────────────────────────
docs/* linguist-documentation
